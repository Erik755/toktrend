APP_ENV=development
AI_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# TikTok Developer / Content Posting API
TIKTOK_CLIENT_KEY=YOUR_TIKTOK_CLIENT_KEY
TIKTOK_CLIENT_SECRET=YOUR_TIKTOK_CLIENT_SECRET
TIKTOK_REDIRECT_URI=http://127.0.0.1:8789/api/tiktok/oauth/callback
TIKTOK_SCOPES=user.info.basic,video.publish
TIKTOK_ACCESS_TOKEN=

# Android Build & Signing Credentials (Release Builds)
# Path to your release JKS upload keystore (absolute or relative to project root)
KEYSTORE_PATH=my-upload-key.jks
# Password for the keystore file
STORE_PASSWORD=YOUR_KEYSTORE_PASSWORD
# Password for the key entry
KEY_PASSWORD=YOUR_KEY_PASSWORD

